{
    "manifest_version": 3,
    "name": "cytos-extensions",
    "version": "1.0.0",
    "description": "Premium Cytos.io Extension with Player List and Engine Hooks",
    "permissions": [
        "storage",
        "scripting",
        "activeTab"
    ],
    "host_permissions": [
        "https://cytos.io/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "content_scripts": [
        {
            "matches": [
                "https://cytos.io/*"
            ],
            "js": [
                "dist/bundle.js"
            ],
            "world": "MAIN",
            "run_at": "document_start"
        }
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}
